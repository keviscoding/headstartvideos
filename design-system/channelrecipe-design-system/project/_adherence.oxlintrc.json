{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/app/**",
              "components/brand/**",
              "components/display/**",
              "components/forms/**",
              "components/recipe/**",
              "ui_kits/**",
              "ui_kits/app/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrowserFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:url|theme|key|ref|className|style|children)$/]",
        "message": "<BrowserFrame> doesn't accept that prop. Declared props: url, theme."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrowserFrame'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<BrowserFrame> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|theme|full|leftIcon|rightIcon|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, theme, full, leftIcon, rightIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|subtle)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'subtle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Button> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CreditsChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:credits|resets|compact|theme|key|ref|className|style|children)$/]",
        "message": "<CreditsChip> doesn't accept that prop. Declared props: credits, resets, compact, theme."
      },
      {
        "selector": "JSXOpeningElement[name.name='CreditsChip'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<CreditsChip> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|theme|leftIcon|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, theme, leftIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Input> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|theme|size|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, theme, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:horizontal|glyph|wordmark)$/]",
        "message": "<Logo> variant must be one of 'horizontal' | 'glyph' | 'wordmark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Logo> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PillBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:theme|dot|key|ref|className|style|children)$/]",
        "message": "<PillBadge> doesn't accept that prop. Declared props: theme, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='PillBadge'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<PillBadge> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stage'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|state|key|ref|className|style|children)$/]",
        "message": "<Stage> doesn't accept that prop. Declared props: label, state."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stage'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:done|active|todo)$/]",
        "message": "<Stage> state must be one of 'done' | 'active' | 'todo'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecipeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|promise|cookTime|credits|rpm|status|theme|selected|onClick|key|ref|className|style|children)$/]",
        "message": "<RecipeCard> doesn't accept that prop. Declared props: name, promise, cookTime, credits, rpm, status, theme, selected, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecipeCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:new|proven|none)$/]",
        "message": "<RecipeCard> status must be one of 'new' | 'proven' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecipeCard'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<RecipeCard> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|theme|key|ref|className|style|children)$/]",
        "message": "<StatusChip> doesn't accept that prop. Declared props: kind, theme."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:new|proven|monetized|warn|error|neutral)$/]",
        "message": "<StatusChip> kind must be one of 'new' | 'proven' | 'monetized' | 'warn' | 'error' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<StatusChip> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|current|theme|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: steps, current, theme."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<Stepper> theme must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='VoiceOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|descriptor|selected|playing|recommended|onSelect|onPlay|theme|key|ref|className|style|children)$/]",
        "message": "<VoiceOption> doesn't accept that prop. Declared props: name, descriptor, selected, playing, recommended, onSelect, onPlay, theme."
      },
      {
        "selector": "JSXOpeningElement[name.name='VoiceOption'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<VoiceOption> theme must be one of 'light' | 'dark'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
