# Required
GEMINI_KEY=your_gemini_api_key

# Optional — unlock additional features
ANTHROPIC_KEY=your_claude_api_key
YOUTUBE_API_KEY=your_youtube_data_api_key
DOWNSUB_KEY=your_downsub_api_key
ATLASCLOUD_KEY=your_atlas_cloud_api_key
# Recipe Brain chat (starter pack always works; chat gated off by default)
RECIPE_BRAIN_ENABLED=0
# Fish Audio voice clone (rights-gated).
# If FISH_API_KEY is set and VOICE_CLONE_ENABLED is unset, clone UI turns on automatically.
FISH_API_KEY=
# VOICE_CLONE_ENABLED=0  # force off even with a key
# VOICE_CLONE_ENABLED=1  # force on (still needs FISH_API_KEY)
VOICE_CLONE_CREDIT_COST=1
# Fish TTS model header. Free promo (fair-use, ~through end of July 2026):
FISH_TTS_MODEL=s2.1-pro-free
# Paid / SLA later: FISH_TTS_MODEL=s2.1-pro
# Hard cap for TTS / studio voiceovers (~150 wpm). Prevents runaway scripts.
MAX_VOICEOVER_MINUTES=25
# High-quality stills (GPT Image 2 Developer on Atlas). Paid plans only.
# HQ_IMAGE_MODEL=openai/gpt-image-2-developer/text-to-image
# HQ_IMAGE_QUALITY=low
# HQ_IMAGE_SIZE=2048x1152
HQ_CREDIT_COST=3
HQ_MAX_MINUTES=12
# Groq — REQUIRED in production for Whisper alignment. Without this, cooks
# fall back to local whisper and freeze the web dyno under load.
GROQ_API_KEY=gsk_...
# Dev only: allow local faster-whisper if Groq is missing (never in production).
# ALLOW_LOCAL_WHISPER=1
HEYGEN_KEY=your_heygen_api_key
PEXELS_KEY=your_pexels_api_key
PIXABAY_KEY=your_pixabay_api_key
RESEND_KEY=your_resend_api_key

# Cook queue — max simultaneous renders on THIS process (web or each worker).
# Keeps ffmpeg/Atlas from melting the site when multiple users cook at once.
MAX_CONCURRENT_COOKS=1
# Cap parallel Atlas TTS jobs (each can take 30–90s).
MAX_CONCURRENT_VOICEOVERS=2
# Threadpool for sync FastAPI routes (voiceover / thumbnail / Gemini).
WEB_THREADPOOL_SIZE=32
# Heuristic minutes-per-cook for queue wait estimates shown in the UI.
EST_MINUTES_PER_COOK=7
# Fallback only — live ETA uses median of recent successful cooks when available.

# How often workers poll for new jobs (seconds).
WORKER_POLL_SECONDS=2
# Reclaim jobs stuck "running" after a dead worker (seconds). Keep short for redeploys.
WORKER_STALE_SECONDS=180
# After SIGTERM, finish in-flight cooks up to this many seconds, then requeue.
WORKER_DRAIN_SECONDS=1200
# Illustration parallelism (paid cooks / trial lite cooks).
ILLUSTRATION_WORKERS=16
ILLUSTRATION_WORKERS_LITE=6

# Optimum (web + workers): set COOK_ON_WEB=0 on the API dyno, then run
#   python -m webapp.worker
# Voiceovers/thumbnails are uploaded to Spaces so workers can fetch them.
# Default COOK_ON_WEB=1 keeps single-dyno behavior (in-process FIFO queue).
COOK_ON_WEB=1

# Elastic cooks on Modal (recommended vs buying more DO workers):
#   COOK_ON_WEB=0
#   COOK_ON_MODAL=1
#   modal secret create channelrecipe-env ...  (see modal_cook.py docstring)
#   modal deploy modal_cook.py
#   Set MODAL_TOKEN_ID + MODAL_TOKEN_SECRET on the web dyno
# Then scale the DO cook-worker component to 0 instances.
COOK_ON_MODAL=0
MODAL_APP_NAME=channelrecipe-cook
MODAL_MAX_CONCURRENT=8

# Fly Machines one-shot cooks (use this if Modal billing rejects your card).
# Guide: install flyctl → fly auth login → fly apps create → secrets → deploy
COOK_ON_FLY=0
FLY_API_TOKEN=
FLY_COOK_APP=channelrecipe-cook
FLY_COOK_IMAGE=
FLY_COOK_REGION=sjc
FLY_COOK_CPUS=2
FLY_COOK_MEMORY_MB=4096


# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Legacy single-tier (backward compat)
STRIPE_PRICE_ID=price_...
STRIPE_PRICE_ID_ANNUAL=price_...
# Two-tier pricing
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_DAILY_MONTHLY=price_...
STRIPE_PRICE_DAILY_ANNUAL=price_...
STRIPE_PRICE_TOPUP_5=price_...
STRIPE_PRICE_TOPUP_15=price_...

# Fernet key (or any passphrase) for encrypting per-user BYOK secrets (HeyGen).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_KEY=

# Admin access (comma-separated emails). Only these accounts can open the
# Settings / API-key endpoints. Leave blank to lock Settings to everyone.
ADMIN_EMAILS=you@example.com

# Telemetry (optional — leave blank to disable). Product analytics + errors.
POSTHOG_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=https://...@...ingest.sentry.io/...

# Email sender (must be on a Resend-verified domain). For quick testing before
# your domain is verified, use: ChannelRecipe <onboarding@resend.dev>
FROM_EMAIL=ChannelRecipe <noreply@channelrecipe.com>

# Database. Leave blank to use a local SQLite file (dev). In production set this
# to your managed Postgres connection string so accounts/credits/subscriptions
# survive redeploys and multiple instances.
DATABASE_URL=postgresql://user:pass@host:25060/dbname?sslmode=require

# Object storage (DigitalOcean Spaces / any S3-compatible). Leave blank to keep
# finished videos on local disk (dev only — lost on redeploy). Set all four of
# KEY/SECRET/BUCKET/ENDPOINT in production so finished videos persist.
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=channelrecipe-media
SPACES_REGION=fra1
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
# Optional CDN base (Spaces "Edge" URL). If set, public links use it.
SPACES_CDN_ENDPOINT=
