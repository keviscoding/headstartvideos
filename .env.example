# Required
GEMINI_KEY=your_gemini_api_key

# Optional — unlock additional features
ANTHROPIC_KEY=your_claude_api_key
YOUTUBE_API_KEY=your_youtube_data_api_key
DOWNSUB_KEY=your_downsub_api_key
ATLASCLOUD_KEY=your_atlas_cloud_api_key
HEYGEN_KEY=your_heygen_api_key
PEXELS_KEY=your_pexels_api_key
PIXABAY_KEY=your_pixabay_api_key
RESEND_KEY=your_resend_api_key

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_PRICE_ID_ANNUAL=price_...

# Admin access (comma-separated emails). Only these accounts can open the
# Settings / API-key endpoints. Leave blank to lock Settings to everyone.
ADMIN_EMAILS=you@example.com
