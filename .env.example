# Required
GEMINI_KEY=your_gemini_api_key

# Optional — unlock additional features
ANTHROPIC_KEY=your_claude_api_key
YOUTUBE_API_KEY=your_youtube_data_api_key
DOWNSUB_KEY=your_downsub_api_key
ATLASCLOUD_KEY=your_atlas_cloud_api_key
# Groq — REQUIRED in production for Whisper alignment. Without this, cooks
# fall back to local whisper and freeze the web dyno under load.
GROQ_API_KEY=gsk_...
# Dev only: allow local faster-whisper if Groq is missing (never in production).
# ALLOW_LOCAL_WHISPER=1
HEYGEN_KEY=your_heygen_api_key
PEXELS_KEY=your_pexels_api_key
PIXABAY_KEY=your_pixabay_api_key
RESEND_KEY=your_resend_api_key

# Cook queue — max simultaneous renders on this process (default 1).
# Keeps ffmpeg/Atlas from melting the site when multiple users cook at once.
# Set to 2 only on a larger droplet after measuring CPU.
MAX_CONCURRENT_COOKS=1
# Heuristic minutes-per-cook for queue wait estimates shown in the UI.
EST_MINUTES_PER_COOK=7
# Illustration parallelism (paid cooks / trial lite cooks).
ILLUSTRATION_WORKERS=16
ILLUSTRATION_WORKERS_LITE=6

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Legacy single-tier (backward compat)
STRIPE_PRICE_ID=price_...
STRIPE_PRICE_ID_ANNUAL=price_...
# Two-tier pricing
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_DAILY_MONTHLY=price_...
STRIPE_PRICE_DAILY_ANNUAL=price_...
STRIPE_PRICE_TOPUP_5=price_...
STRIPE_PRICE_TOPUP_15=price_...

# Admin access (comma-separated emails). Only these accounts can open the
# Settings / API-key endpoints. Leave blank to lock Settings to everyone.
ADMIN_EMAILS=you@example.com

# Telemetry (optional — leave blank to disable). Product analytics + errors.
POSTHOG_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=https://...@...ingest.sentry.io/...

# Email sender (must be on a Resend-verified domain). For quick testing before
# your domain is verified, use: ChannelRecipe <onboarding@resend.dev>
FROM_EMAIL=ChannelRecipe <noreply@channelrecipe.com>

# Database. Leave blank to use a local SQLite file (dev). In production set this
# to your managed Postgres connection string so accounts/credits/subscriptions
# survive redeploys and multiple instances.
DATABASE_URL=postgresql://user:pass@host:25060/dbname?sslmode=require

# Object storage (DigitalOcean Spaces / any S3-compatible). Leave blank to keep
# finished videos on local disk (dev only — lost on redeploy). Set all four of
# KEY/SECRET/BUCKET/ENDPOINT in production so finished videos persist.
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=channelrecipe-media
SPACES_REGION=fra1
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
# Optional CDN base (Spaces "Edge" URL). If set, public links use it.
SPACES_CDN_ENDPOINT=
